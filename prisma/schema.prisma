generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Position {
  id               Int               @id @default(autoincrement())
  name             String            @unique @db.VarChar(100)
  description      String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  employeeProfiles EmployeeProfile[]

  @@map("positions")
}

model Department {
  id               Int               @id @default(autoincrement())
  name             String            @unique @db.VarChar(100)
  description      String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  employeeProfiles EmployeeProfile[]

  @@map("departments")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]

  @@map("roles")
}

model EmployeeStatusModel {
  id               Int               @id @default(autoincrement())
  name             String            @unique @db.VarChar(50)
  description      String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  employeeProfiles EmployeeProfile[]

  @@map("employee_statuses")
}

model Industry {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  brands      Brand[]

  @@map("industries")
}

model User {
  id              Int              @id @default(autoincrement())
  username        String           @unique @db.VarChar(50)
  passwordHash    String           @map("password_hash") @db.VarChar(255)
  salt            String           @db.VarChar(255)
  createdAt       DateTime         @default(now()) @map("created_at")
  roleId          Int              @default(3) @map("role_id")
  employeeProfile EmployeeProfile?
  teamMembers     TeamMember[]
  role            Role             @relation(fields: [roleId], references: [id])
  calendarEvents  CalendarEvent[]
  leaveCredits    LeaveCredit[]
  leaveRequests   LeaveRequest[]
  reviewedLeaves  LeaveRequest[] @relation("ReviewedLeaves")

  @@index([roleId], map: "users_role_id_fkey")
  @@map("users")
}

model EmployeeProfile {
  id            Int                 @id @default(autoincrement())
  userId        Int                 @unique @map("user_id")
  firstName     String              @map("first_name") @db.VarChar(100)
  lastName      String              @map("last_name") @db.VarChar(100)
  middleName    String?             @map("middle_name") @db.VarChar(100)
  dateOfBirth   DateTime?           @map("date_of_birth")
  contactNumber String?             @map("contact_number") @db.VarChar(20)
  personalEmail String?             @map("personal_email") @db.VarChar(255)
  address       String?             @db.Text
  hireDate      DateTime?           @map("hire_date")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  departmentId  Int?                @map("department_id")
  positionId    Int?                @map("position_id")
  statusId      Int                 @default(1) @map("status_id")
  department    Department?         @relation(fields: [departmentId], references: [id])
  position      Position?           @relation(fields: [positionId], references: [id])
  status        EmployeeStatusModel @relation(fields: [statusId], references: [id])
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([departmentId], map: "employee_profiles_department_id_fkey")
  @@index([positionId], map: "employee_profiles_position_id_fkey")
  @@index([statusId], map: "employee_profiles_status_id_fkey")
  @@map("employee_profiles")
}

model Brand {
  id          Int         @id @default(autoincrement())
  name        String      @unique @db.VarChar(100)
  description String?     @db.Text
  logo        String?     @db.VarChar(500)
  website     String?     @db.VarChar(255)
  status      BrandStatus @default(active)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  createdBy   Int         @map("created_by")
  industryId  Int?        @map("industry_id")
  industry    Industry?   @relation(fields: [industryId], references: [id])
  teams       Team[]

  @@index([industryId], map: "brands_industry_id_fkey")
  @@map("brands")
}

model Team {
  id          Int           @id @default(autoincrement())
  name        String        @unique @db.VarChar(100)
  description String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  brandId     Int           @map("brand_id")
  history     TeamHistory[]
  members     TeamMember[]
  brand       Brand         @relation(fields: [brandId], references: [id])

  @@index([brandId], map: "teams_brand_id_fkey")
  @@map("teams")
}

model TeamMember {
  id       Int              @id @default(autoincrement())
  teamId   Int              @map("team_id")
  userId   Int              @map("user_id")
  isLeader Boolean          @default(false) @map("is_leader")
  status   TeamMemberStatus @default(active)
  joinedAt DateTime         @default(now()) @map("joined_at")
  leftAt   DateTime?        @map("left_at")
  history  TeamHistory[]
  team     Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId], map: "team_members_team_id_fkey")
  @@index([userId], map: "team_members_user_id_fkey")
  @@map("team_members")
}

model TeamHistory {
  id           Int               @id @default(autoincrement())
  teamId       Int               @map("team_id")
  teamMemberId Int?              @map("team_member_id")
  action       TeamHistoryAction
  performedBy  Int               @map("performed_by")
  reason       String?           @db.Text
  metadata     Json?
  createdAt    DateTime          @default(now()) @map("created_at")
  team         Team              @relation(fields: [teamId], references: [id])
  teamMember   TeamMember?       @relation(fields: [teamMemberId], references: [id])

  @@index([teamId], map: "team_history_team_id_fkey")
  @@index([teamMemberId], map: "team_history_team_member_id_fkey")
  @@map("team_history")
}

enum BrandStatus {
  active
  inactive
  archived
}

enum TeamMemberStatus {
  active
  inactive
}

enum TeamHistoryAction {
  joined
  left
  promoted
  demoted
  removed
  created
  updated
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(200)
  description String?  @db.Text
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  color       String   @default("blue") @db.VarChar(20)
  createdBy   Int      @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [createdBy], references: [id])

  @@index([startDate], map: "calendar_events_start_date_idx")
  @@index([createdBy], map: "calendar_events_created_by_idx")
  @@map("calendar_events")
}

model LeaveType {
  id               Int           @id @default(autoincrement())
  name             String        @unique @db.VarChar(50)
  description      String?       @db.Text
  defaultDaysLimit Int?          @map("default_days_limit")
  color            String        @default("purple") @db.VarChar(20)
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at")
  leaveRequests    LeaveRequest[]

  @@map("leave_types")
}

model LeaveStatus {
  id            Int           @id @default(autoincrement())
  name          String        @unique @db.VarChar(50)
  description   String?       @db.Text
  color         String        @default("gray") @db.VarChar(20)
  isFinal       Boolean       @default(false) @map("is_final")
  createdAt     DateTime      @default(now()) @map("created_at")
  leaveRequests LeaveRequest[]

  @@map("leave_statuses")
}

model LeaveCredit {
  id         Int           @id @default(autoincrement())
  userId     Int           @map("user_id")
  earnedDate DateTime      @map("earned_date")
  usedDate   DateTime?     @map("used_date")
  createdAt  DateTime      @default(now()) @map("created_at")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveUsage LeaveUsage[]

  @@index([userId], map: "leave_credits_user_id_idx")
  @@index([earnedDate], map: "leave_credits_earned_date_idx")
  @@map("leave_credits")
}

model LeaveRequest {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  leaveTypeId   Int       @map("leave_type_id")
  statusId      Int       @default(1) @map("status_id")
  startDate     DateTime  @map("start_date")
  endDate       DateTime  @map("end_date")
  reason        String?   @db.Text
  isPaid        Boolean   @default(true) @map("is_paid")
  reviewedBy    Int?      @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewComment String?   @map("review_comment") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User         @relation(fields: [userId], references: [id])
  leaveType     LeaveType    @relation(fields: [leaveTypeId], references: [id])
  status        LeaveStatus  @relation(fields: [statusId], references: [id])
  reviewer      User?        @relation("ReviewedLeaves", fields: [reviewedBy], references: [id])
  leaveUsage    LeaveUsage[]

  @@index([userId], map: "leave_requests_user_id_idx")
  @@index([statusId], map: "leave_requests_status_id_idx")
  @@index([leaveTypeId], map: "leave_requests_leave_type_id_idx")
  @@index([startDate], map: "leave_requests_start_date_idx")
  @@map("leave_requests")
}

model LeaveUsage {
  id            Int          @id @default(autoincrement())
  leaveRequestId Int         @map("leave_request_id")
  leaveCreditId  Int         @map("leave_credit_id")
  createdAt     DateTime     @default(now()) @map("created_at")

  leaveRequest  LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  leaveCredit   LeaveCredit  @relation(fields: [leaveCreditId], references: [id], onDelete: Cascade)

  @@unique([leaveRequestId, leaveCreditId])
  @@index([leaveRequestId], map: "leave_usage_leave_request_id_idx")
  @@index([leaveCreditId], map: "leave_usage_leave_credit_id_idx")
  @@map("leave_usage")
}
