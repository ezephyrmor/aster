# ------------------------------------------------------------------------------
# ASTER HR SYSTEM - SAMPLE ENVIRONMENT CONFIGURATION
# Copy this file to .env and adjust values for your environment
# ------------------------------------------------------------------------------

# Database connection string for MySQL
DATABASE_URL="mysql://root:aster_root_password@localhost:3306/aster_db"

# NextAuth secret (for session management)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="aster-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Password pepper (secret value for password hashing)
# This should be a random string and kept secret - never commit to version control
# Generate with: openssl rand -base64 32
PASSWORD_PEPPER=change-this-to-a-random-secret-in-production

# Demo mode - set to "true" to enable demo mode (no database required)
# DEMO_MODE=true

AUTHJS_LOGGER_LEVEL=silent